---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Página no encontrada — Baldurion"
  description="Esta página no existe o fue movida."
  locale="es"
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-32 text-center">
    <p class="font-display text-8xl md:text-9xl text-[var(--color-border)]" style="font-family: var(--font-display);">404</p>
    <h1 class="font-display text-3xl md:text-4xl mt-4 mb-4" style="font-family: var(--font-display);">PÁGINA NO ENCONTRADA</h1>
    <p class="text-[var(--color-text-muted)] mb-8">Esta página no existe o fue movida a otra URL.</p>
    <a
      href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}es/`}
      class="inline-flex items-center gap-2 bg-[var(--color-text)] text-[var(--color-bg)] font-bold px-8 py-4 rounded-full hover:opacity-80 transition-opacity duration-200"
    >
      Volver al inicio
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </div>
</BaseLayout>
