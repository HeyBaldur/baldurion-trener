---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import HomeHero from '../../components/HomeHero.astro';
import { es } from '../../i18n/es';
import { getCollection } from 'astro:content';

const locale = 'es';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const allArticulos = await getCollection('articulos', ({ id, data }) => {
  return id.startsWith('es/') && !data.draft;
});

const articulos = allArticulos
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 7)
  .map(a => ({
    title: a.data.title,
    description: a.data.description,
    slug: a.id.replace('es/', ''),
    category: a.data.category,
    pubDate: a.data.pubDate,
    heroImage: a.data.heroImage,
    heroImageAlt: a.data.heroImageAlt,
    readingTime: a.data.readingTime,
    body: a.body ?? '',
  }));
---

<BaseLayout
  title="Baldurion — Fitness con base científica"
  description="Entrenamiento personalizado con rigor científico. Fuerza real, capacidad real. Entrenador personal en Katowice."
  locale={locale}
>
  <HomeHero t={es.home.hero} base={base} locale={locale} />
  <div class="py-6 lg:py-10">
    <BentoGrid articles={articulos} locale={locale} />
  </div>
</BaseLayout>
