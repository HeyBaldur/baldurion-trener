---
import ArticuloLayout from '../../../layouts/ArticuloLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const esArticulos = await getCollection('articulos', ({ id, data }) => {
    return id.startsWith('es/') && !data.draft;
  });

  return esArticulos.map(entry => ({
    params: { slug: entry.id.replace('es/', '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const locale = 'es';
const slug = entry.id.replace('es/', '');

const allArticulos = await getCollection('articulos', ({ id, data }) => {
  return id.startsWith('es/') && !data.draft && id !== entry.id;
});

const related = allArticulos
  .filter(a => a.data.category === entry.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2)
  .map(a => ({
    title: a.data.title,
    description: a.data.description,
    slug: a.id.replace('es/', ''),
    category: a.data.category,
    pubDate: a.data.pubDate,
    heroImage: a.data.heroImage,
    heroImageAlt: a.data.heroImageAlt,
    readingTime: a.data.readingTime,
  }));

const siteURL = 'https://baldurion.com';
const alternates = {
  es: `${siteURL}/es/articulos/${slug}/`,
  en: `${siteURL}/en/articulos/${slug}/`,
  pl: `${siteURL}/pl/articulos/${slug}/`,
};
---

<ArticuloLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  author={entry.data.author}
  category={entry.data.category}
  tags={entry.data.tags}
  heroImage={entry.data.heroImage}
  heroImageAlt={entry.data.heroImageAlt}
  readingTime={entry.data.readingTime}
  rawBody={entry.body ?? ''}
  locale={locale}
  slug={slug}
  relatedArticles={related}
  alternates={alternates}
>
  <Content />
</ArticuloLayout>
