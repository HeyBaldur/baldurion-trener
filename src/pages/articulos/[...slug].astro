---
import ArticuloLayout from '../../layouts/ArticuloLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const esArticulos = await getCollection('articulos', ({ id, data }) => id.startsWith('es/') && !data.draft);
  const enArticulos = await getCollection('articulos', ({ id, data }) => id.startsWith('en/') && !data.draft);
  const enIds = new Set(enArticulos.map(a => a.id.replace('en/', '')));

  const paths = [];
  for (const esEntry of esArticulos) {
    const slug = esEntry.id.replace('es/', '');
    const enEntry = enArticulos.find(a => a.id.replace('en/', '') === slug);
    paths.push({
      params: { slug },
      props: { entry: enEntry ?? esEntry, isTranslationFallback: !enIds.has(slug) },
    });
  }
  for (const enEntry of enArticulos) {
    const slug = enEntry.id.replace('en/', '');
    if (!paths.find(p => p.params.slug === slug)) {
      paths.push({ params: { slug }, props: { entry: enEntry, isTranslationFallback: false } });
    }
  }
  return paths;
}

const { entry, isTranslationFallback } = Astro.props;
const { Content } = await render(entry);
const locale = 'en';
const slug = entry.id.replace(/^(es|en|pl)\//, '');
const siteURL = 'https://baldurion.com';

const allEs = await getCollection('articulos', ({ id, data }) => id.startsWith('es/') && !data.draft && id !== entry.id);
const related = allEs
  .filter(a => a.data.category === entry.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2)
  .map(a => ({
    title: a.data.title,
    description: a.data.description,
    slug: a.id.replace('es/', ''),
    category: a.data.category,
    pubDate: a.data.pubDate,
    heroImage: a.data.heroImage,
    heroImageAlt: a.data.heroImageAlt,
    readingTime: a.data.readingTime,
  }));

const alternates = {
  es: `${siteURL}/es/articulos/${slug}/`,
  en: `${siteURL}/en/articulos/${slug}/`,
  pl: `${siteURL}/pl/articulos/${slug}/`,
};
---

<ArticuloLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updatedDate={entry.data.updatedDate}
  author={entry.data.author}
  category={entry.data.category}
  tags={entry.data.tags}
  heroImage={entry.data.heroImage}
  heroImageAlt={entry.data.heroImageAlt}
  readingTime={entry.data.readingTime}
  rawBody={entry.body ?? ''}
  locale={locale}
  slug={slug}
  relatedArticles={related}
  alternates={alternates}
  isTranslationFallback={isTranslationFallback}
>
  <Content />
</ArticuloLayout>
