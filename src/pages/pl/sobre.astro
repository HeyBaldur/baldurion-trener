---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutPage from '../../components/AboutPage.astro';
import { useTranslations } from '../../i18n/index';

const locale = 'pl';
const t = useTranslations(locale);
const cutoutSrc = '/images/about/rudolf-cutout.png';
const siteURL = 'https://baldurion.com';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Rudolf Jaubert',
  image: `${siteURL}${cutoutSrc}`,
  jobTitle: 'Personal Trainer',
  address: { '@type': 'PostalAddress', addressLocality: 'Katowice', addressCountry: 'PL' },
  knowsAbout: ['Strength training', 'Athletics', 'Martial arts', 'Sports nutrition'],
};
---

<BaseLayout
  title={t.about.metaTitle}
  description={t.about.metaDescription}
  locale={locale}
  image={cutoutSrc}
  schema={schema}
>
  <AboutPage t={t.about} locale={locale} />
</BaseLayout>
