---
import ArticuloLayout from '../../../layouts/ArticuloLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const esArticulos = await getCollection('articulos', ({ id, data }) => id.startsWith('es/') && !data.draft);
  const plArticulos = await getCollection('articulos', ({ id, data }) => id.startsWith('pl/') && !data.draft);
  const plIds = new Set(plArticulos.map(a => a.id.replace('pl/', '')));

  const paths = [];
  for (const esEntry of esArticulos) {
    const slug = esEntry.id.replace('es/', '');
    const plEntry = plArticulos.find(a => a.id.replace('pl/', '') === slug);
    paths.push({ params: { slug }, props: { entry: plEntry ?? esEntry, isTranslationFallback: !plIds.has(slug) } });
  }
  for (const plEntry of plArticulos) {
    const slug = plEntry.id.replace('pl/', '');
    if (!paths.find(p => p.params.slug === slug)) {
      paths.push({ params: { slug }, props: { entry: plEntry, isTranslationFallback: false } });
    }
  }
  return paths;
}

const { entry, isTranslationFallback } = Astro.props;
const { Content } = await render(entry);
const locale = 'pl';
const slug = entry.id.replace(/^(es|en|pl)\//, '');
const siteURL = 'https://baldurion.com';

const allEs = await getCollection('articulos', ({ id, data }) => id.startsWith('es/') && !data.draft && id !== entry.id);
const related = allEs
  .filter(a => a.data.category === entry.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2)
  .map(a => ({
    title: a.data.title, description: a.data.description, slug: a.id.replace('es/', ''),
    category: a.data.category, pubDate: a.data.pubDate, heroImage: a.data.heroImage, heroImageAlt: a.data.heroImageAlt, readingTime: a.data.readingTime,
  }));

const alternates = {
  es: `${siteURL}/es/articulos/${slug}/`,
  en: `${siteURL}/en/articulos/${slug}/`,
  pl: `${siteURL}/pl/articulos/${slug}/`,
};
---

<ArticuloLayout title={entry.data.title} description={entry.data.description} pubDate={entry.data.pubDate} updatedDate={entry.data.updatedDate} author={entry.data.author} category={entry.data.category} tags={entry.data.tags} heroImage={entry.data.heroImage} heroImageAlt={entry.data.heroImageAlt} readingTime={entry.data.readingTime} rawBody={entry.body ?? ''} locale={locale} slug={slug} relatedArticles={related} alternates={alternates} isTranslationFallback={isTranslationFallback}>
  <Content />
</ArticuloLayout>
