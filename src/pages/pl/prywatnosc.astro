const toc = [
  { id: 'administrator', label: 'Administrator danych' },
  { id: 'dane', label: 'Jakie dane zbieramy' },
  { id: 'kontakt', label: 'Gdy się z nami kontaktujesz' },
  { id: 'osadzone', label: 'Osadzone treści zewnętrzne' },
