---
import type { Locale } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const lp = locale === 'en' ? base : `${base}${locale}/`;
const cookiesHref = `${lp}cookies/`;
---

<div
  id="consent-banner"
  role="region"
  aria-label={t.banner.title}
  class="hidden fixed bottom-[40px] right-[40px] z-50 w-[420px] max-w-[calc(100vw-48px)] p-[24px] rounded-[16px] border border-[#D4E84A] opacity-0 translate-y-[20px] transition-[opacity,transform] duration-[400ms] ease-[cubic-bezier(0.16,1,0.3,1)] max-[639px]:bottom-[24px] max-[639px]:right-[16px] max-[639px]:left-[16px] max-[639px]:w-auto max-[639px]:max-w-none max-[639px]:p-[20px] bg-white dark:bg-[#0F0F0F] shadow-[0_8px_32px_rgba(0,0,0,0.08),0_0_0_1px_rgba(212,232,74,0.15)] dark:shadow-[0_8px_32px_rgba(0,0,0,0.5),0_0_0_1px_rgba(212,232,74,0.1)]"
>
  <button
    id="consent-close"
    class="absolute top-[14px] right-[14px] w-[32px] h-[32px] flex items-center justify-center bg-transparent border-none cursor-pointer text-[#888] transition-colors duration-150 rounded-full hover:text-white dark:hover:text-white [data-theme=light_&]:hover:text-[#0A0A0A]"
    aria-label="Close"
  >
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="1" y1="1" x2="13" y2="13"/>
      <line x1="13" y1="1" x2="1" y2="13"/>
    </svg>
  </button>

  <div class="flex items-center gap-[7px] mb-[12px]">
    <span class="w-[8px] h-[8px] rounded-full bg-[#D4E84A] shrink-0"></span>
    <span class="text-[11px] font-bold tracking-[0.2em] leading-[1] text-[#D4E84A] dark:text-[#D4E84A] [data-theme=light_&]:text-[#444444]">{t.banner.eyebrow.toUpperCase()}</span>
  </div>

  <h2 class="text-[18px] leading-[1.2] m-0 text-[#0A0A0A] dark:text-white" style="font-family: var(--font-display);">
    {t.banner.title}
  </h2>
  <p class="text-[13.5px] leading-[1.55] mt-[8px] mb-0 text-[#555555] dark:text-[#999999]" style="font-family: var(--font-body);">
    {t.banner.body}
  </p>

  <div class="flex justify-between items-center gap-[12px] mt-[20px] max-[639px]:flex-col-reverse max-[639px]:items-stretch">
    <button
      id="consent-dismiss"
      class="rounded-full bg-[#D4E84A] text-[#0A0A0A] border-none px-[20px] py-[10px] font-bold text-[13px] cursor-pointer transition-opacity duration-150 hover:opacity-85 whitespace-nowrap"
    >
      {t.banner.primaryAction}
    </button>
    <a
      href={cookiesHref}
      class="text-[13px] no-underline transition-[text-decoration,opacity] duration-150 text-[#0A0A0A] dark:text-white hover:underline hover:opacity-70 max-[639px]:text-center"
    >
      {t.banner.secondaryAction}
    </a>
  </div>
</div>

<script>
const banner = document.getElementById('consent-banner') as HTMLElement | null;
const dismissBtn = document.getElementById('consent-dismiss');
const closeBtn = document.getElementById('consent-close');

function dismiss() {
  if (!banner) return;
  banner.classList.remove('is-visible');
  banner.classList.add('is-hiding');
  setTimeout(() => {
    banner.style.display = 'none';
    banner.classList.remove('is-hiding');
  }, 250);
  localStorage.setItem('baldurion_banner_dismissed', 'true');
}

if (banner && localStorage.getItem('baldurion_banner_dismissed') !== 'true') {
  setTimeout(() => {
    banner.style.display = 'block';
    banner.getBoundingClientRect(); // force reflow before transition
    banner.classList.add('is-visible');
  }, 1200);
}

dismissBtn?.addEventListener('click', dismiss);
closeBtn?.addEventListener('click', dismiss);

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && banner?.style.display === 'block') dismiss();
});
</script>

<style is:global>
  #consent-banner.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  #consent-banner.is-hiding {
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 250ms ease-in, transform 250ms ease-in;
  }
  @media (max-width: 639px) {
    #consent-banner {
      bottom: calc(24px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>
