---
import type { Locale } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  locale: Locale;
  size?: 'xl' | 'm' | 's';
}

const { locale, size = 'm' } = Astro.props;
const t = useTranslations(locale);

const personajeSrc = '/images/brand/baldurion-personaje.png';
const eyebrow = t.brand.eyebrow.toUpperCase();
---

{size === 'xl' && (
  <div style="display:inline-flex;align-items:center;gap:22px;">
    <div style="width:96px;height:96px;border-radius:16px;overflow:hidden;background-color:var(--color-border);flex-shrink:0;">
      <img
        src={personajeSrc}
        alt="Baldurion"
        width="96"
        height="96"
        loading="lazy"
        style="width:100%;height:100%;object-fit:cover;display:block;"
      />
    </div>
    <div style="display:flex;flex-direction:column;gap:4px;">
      <span style="font-family:var(--font-body);font-size:13px;font-weight:700;letter-spacing:0.3em;text-transform:uppercase;line-height:1;color:#D4E84A;">
        {eyebrow}
      </span>
      <span style="font-family:var(--font-display);font-size:48px;letter-spacing:0.01em;line-height:0.95;text-transform:uppercase;color:var(--color-text);">
        BALDURION
      </span>
    </div>
  </div>
)}

{size === 'm' && (
  <div style="display:inline-flex;align-items:center;gap:18px;">
    <div style="width:56px;height:56px;border-radius:10px;overflow:hidden;background-color:var(--color-border);flex-shrink:0;">
      <img
        src={personajeSrc}
        alt=""
        width="56"
        height="56"
        loading="eager"
        style="width:100%;height:100%;object-fit:cover;display:block;"
      />
    </div>
    <div style="display:flex;flex-direction:column;gap:4px;">
      <span style="font-family:var(--font-body);font-size:9px;font-weight:700;letter-spacing:0.25em;text-transform:uppercase;line-height:1;color:#D4E84A;">
        {eyebrow}
      </span>
      <span style="font-family:var(--font-display);font-size:28px;letter-spacing:0.01em;line-height:0.95;text-transform:uppercase;color:var(--color-text);">
        BALDURION
      </span>
    </div>
  </div>
)}

{size === 's' && (
  <div style="display:inline-flex;align-items:center;gap:12px;">
    <div style="width:40px;height:40px;border-radius:8px;overflow:hidden;background-color:var(--color-border);flex-shrink:0;">
      <img
        src={personajeSrc}
        alt=""
        width="40"
        height="40"
        loading="lazy"
        style="width:100%;height:100%;object-fit:cover;display:block;"
      />
    </div>
    <div style="display:flex;flex-direction:column;gap:4px;">
      <span style="font-family:var(--font-body);font-size:7px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;line-height:1;color:#D4E84A;">
        {eyebrow}
      </span>
      <span style="font-family:var(--font-display);font-size:20px;letter-spacing:0.01em;line-height:0.95;text-transform:uppercase;color:var(--color-text);">
        BALDURION
      </span>
    </div>
  </div>
)}
