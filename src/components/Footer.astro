---
import Logo from './Logo.astro';
import type { Locale } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const lp = locale === 'en' ? base : `${base}${locale}/`;

const legalPaths: Record<Locale, { privacy: string; cookies: string; legal: string; terms: string; preferences: string }> = {
  es: { privacy: 'privacidad', cookies: 'cookies', legal: 'aviso-legal', terms: 'terminos', preferences: 'preferencias' },
  en: { privacy: 'privacy', cookies: 'cookies', legal: 'legal-notice', terms: 'terms', preferences: 'preferences' },
  pl: { privacy: 'prywatnosc', cookies: 'cookies', legal: 'nota-prawna', terms: 'regulamin', preferences: 'preferencje' },
};
---

<footer class="mt-[96px] border-t border-[rgba(0,0,0,0.06)] dark:border-[rgba(255,255,255,0.06)] max-[640px]:mt-[64px]">
  <div class="max-w-[1280px] mx-auto px-[32px] pt-[64px] pb-[32px] max-[640px]:px-[20px] max-[640px]:pt-[48px] max-[640px]:pb-[24px]">

    <div class="grid grid-cols-[1.2fr_1fr_1fr_1.4fr] gap-[48px] items-start mb-[48px] max-[1024px]:grid-cols-2 max-[1024px]:gap-[40px] max-[640px]:grid-cols-1 max-[640px]:gap-[32px] max-[640px]:mb-[32px]">

      <!-- Brand column -->
      <div class="flex flex-col">
        <a href={lp} aria-label="Baldurion — inicio">
          <Logo locale={locale} size="s" />
        </a>
        <p class="text-[13px] leading-[1.5] mt-[14px] max-w-[220px] text-[rgba(0,0,0,0.45)] dark:text-[rgba(255,255,255,0.4)]">
          {t.footer.tagline}
        </p>
      </div>

      <!-- Nav column -->
      <div class="flex flex-col">
        <p class="text-[11px] font-bold tracking-[0.25em] uppercase m-0 mb-[20px] text-[rgba(0,0,0,0.35)] dark:text-[rgba(255,255,255,0.3)]">
          {t.footer.navTitle}
        </p>
        <nav class="flex flex-col gap-[12px]">
          <a href={lp} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.nav.home}</a>
          <a href={`${lp}articulos/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.nav.articles}</a>
          <a href={`${lp}coaching/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.nav.coaching}</a>
          <a href={`${lp}sobre/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.nav.about}</a>
          <a href={`${lp}contacto/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.nav.contact}</a>
        </nav>
      </div>

      <!-- Legal column -->
      <div class="flex flex-col">
        <p class="text-[11px] font-bold tracking-[0.25em] uppercase m-0 mb-[20px] text-[rgba(0,0,0,0.35)] dark:text-[rgba(255,255,255,0.3)]">
          {t.footer.legalTitle}
        </p>
        <nav class="flex flex-col gap-[12px]">
          <a href={`${lp}${legalPaths[locale].privacy}/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.footer.privacy}</a>
          <a href={`${lp}${legalPaths[locale].cookies}/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.footer.cookies}</a>
          <a href={`${lp}${legalPaths[locale].legal}/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.footer.legalNotice}</a>
          <a href={`${lp}${legalPaths[locale].terms}/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.footer.terms}</a>
          <a href={`${lp}${legalPaths[locale].preferences}/`} class="text-[14px] no-underline transition-colors duration-200 text-[rgba(0,0,0,0.6)] dark:text-[rgba(255,255,255,0.6)] hover:text-dark dark:hover:text-lime">{t.footer.preferences}</a>
        </nav>
      </div>

      <!-- Institutional column -->
      <div class="flex flex-col gap-[20px] max-[1024px]:col-span-full max-[1024px]:flex-row max-[1024px]:flex-wrap max-[1024px]:gap-[32px] max-[1024px]:items-center max-[1024px]:pt-[32px] max-[1024px]:border-t max-[1024px]:border-[rgba(0,0,0,0.06)] dark:max-[1024px]:border-[rgba(255,255,255,0.06)] max-[640px]:flex-col max-[640px]:items-start max-[640px]:pt-0 max-[640px]:border-t-0">

        <div class="flex items-start gap-[12px]">
          <svg viewBox="0 0 810 540" width="64" height="42" role="img" aria-label={t.footer.euTitle} class="rounded-[4px] shrink-0 shadow-[0_4px_12px_rgba(0,0,0,0.35)] border border-[rgba(0,0,0,0.08)] dark:border-[rgba(255,255,255,0.06)]">
            <rect width="810" height="540" fill="#003399"></rect>
            <polygon points="405,60 412.05,80.29 433.53,80.73 416.41,93.71 422.63,114.27 405,102 387.37,114.27 393.59,93.71 376.47,80.73 397.95,80.29" fill="#FFCC00"></polygon>
            <polygon points="495,84.12 502.05,104.41 523.53,104.85 506.41,117.83 512.63,138.39 495,126.12 477.37,138.39 483.59,117.83 466.47,104.85 487.95,104.41" fill="#FFCC00"></polygon>
            <polygon points="560.88,150 567.93,170.29 589.41,170.73 572.29,183.71 578.51,204.27 560.88,192 543.25,204.27 549.47,183.71 532.35,170.73 553.83,170.29" fill="#FFCC00"></polygon>
            <polygon points="585,240 592.05,260.29 613.53,260.73 596.41,273.71 602.63,294.27 585,282 567.37,294.27 573.59,273.71 556.47,260.73 577.95,260.29" fill="#FFCC00"></polygon>
            <polygon points="560.88,330 567.93,350.29 589.41,350.73 572.29,363.71 578.51,384.27 560.88,372 543.25,384.27 549.47,363.71 532.35,350.73 553.83,350.29" fill="#FFCC00"></polygon>
            <polygon points="495,395.88 502.05,416.17 523.53,416.61 506.41,429.59 512.63,450.15 495,437.88 477.37,450.15 483.59,429.59 466.47,416.61 487.95,416.17" fill="#FFCC00"></polygon>
            <polygon points="405,420 412.05,440.29 433.53,440.73 416.41,453.71 422.63,474.27 405,462 387.37,474.27 393.59,453.71 376.47,440.73 397.95,440.29" fill="#FFCC00"></polygon>
            <polygon points="315,395.88 322.05,416.17 343.53,416.61 326.41,429.59 332.63,450.15 315,437.88 297.37,450.15 303.59,429.59 286.47,416.61 307.95,416.17" fill="#FFCC00"></polygon>
            <polygon points="249.12,330 256.17,350.29 277.65,350.73 260.53,363.71 266.75,384.27 249.12,372 231.49,384.27 237.71,183.71 220.59,350.73 242.07,350.29" fill="#FFCC00"></polygon>
            <polygon points="225,240 232.05,260.29 253.53,260.73 236.41,273.71 242.63,294.27 225,282 207.37,294.27 213.59,273.71 196.47,260.73 217.95,260.29" fill="#FFCC00"></polygon>
            <polygon points="249.12,150 256.17,170.29 277.65,170.73 260.53,183.71 266.75,204.27 249.12,192 231.49,204.27 237.71,183.71 220.59,170.73 242.07,170.29" fill="#FFCC00"></polygon>
            <polygon points="315,84.12 322.05,104.41 343.53,104.85 326.41,117.83 332.63,138.39 315,126.12 297.37,138.39 303.59,117.83 286.47,104.85 307.95,104.41" fill="#FFCC00"></polygon>
          </svg>
          <div class="flex flex-col">
            <p class="text-[13px] font-bold leading-[1.3] m-0 mb-[3px] text-[rgba(0,0,0,0.8)] dark:text-[rgba(255,255,255,0.8)]">{t.footer.euTitle}</p>
            <p class="text-[11px] leading-[1.4] m-0 mb-[8px] text-[rgba(0,0,0,0.45)] dark:text-[rgba(255,255,255,0.4)]">{t.footer.euSubtitle}</p>
          </div>
        </div>

        <a
          href="#"
          class="inline-flex items-center gap-[12px] h-[52px] px-[18px] bg-black border border-[rgba(255,255,255,0.2)] rounded-full no-underline transition-[background,border-color,transform] duration-200 shadow-[0_8px_24px_rgba(0,0,0,0.35)] w-fit hover:bg-[rgba(255,255,255,0.06)] hover:border-[rgba(255,255,255,0.35)] hover:scale-[1.03] active:scale-[0.97]"
          aria-label={t.footer.googlePlayAriaLabel}
        >
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" aria-hidden="true" class="shrink-0">
            <path d="M3.18 23.76c.32.18.7.2 1.06.02l12.76-7.37-2.93-2.93-10.89 10.28z" fill="#EA4335"></path>
            <path d="M22.33 10.63l-3.12-1.8-3.25 3.24 3.25 3.25 3.15-1.82c.9-.52.9-1.84-.03-2.87z" fill="#FBBC05"></path>
            <path d="M2.12 2.24A1.36 1.36 0 002 2.95v18.1c0 .26.04.5.12.71l.06.06L12.32 12v-.24L2.18 2.18l-.06.06z" fill="#4285F4"></path>
            <path d="M14.07 12l3.05-3.05L4.24 1.6A1.18 1.18 0 003.19 1.6L14.07 12z" fill="#34A853"></path>
          </svg>
          <div class="flex flex-col items-start leading-[1]">
            <span class="text-[rgba(255,255,255,0.5)] text-[10px] font-medium tracking-[0.15em] uppercase mb-[2px]">{t.footer.googlePlayKicker}</span>
            <span class="text-white text-[16px] font-semibold tracking-[-0.01em]">{t.footer.googlePlayLabel}</span>
          </div>
        </a>

      </div>
    </div>

    <div class="text-center text-[11px] font-bold tracking-[0.3em] uppercase py-[28px] mb-[24px] text-[rgba(0,0,0,0.3)] dark:text-[rgba(255,255,255,0.25)] border-t border-b border-[rgba(0,0,0,0.06)] dark:border-[rgba(255,255,255,0.06)]">
      {t.footer.taglineCentral}
    </div>

    <div class="flex justify-between items-center flex-wrap gap-[16px] max-[640px]:flex-col max-[640px]:items-start">
      <p class="text-[12px] m-0 text-[rgba(0,0,0,0.35)] dark:text-[rgba(255,255,255,0.3)]">
        &copy; {year} Baldurion &middot; {t.footer.copyright}
      </p>
      <div class="flex items-center gap-[16px]">
        <a href="https://www.instagram.com/baldurion_fitness/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex transition-colors duration-200 text-[rgba(0,0,0,0.4)] dark:text-[rgba(255,255,255,0.35)] hover:text-dark dark:hover:text-[rgba(255,255,255,0.9)]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@BaldurionFitness" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="flex transition-colors duration-200 text-[rgba(0,0,0,0.4)] dark:text-[rgba(255,255,255,0.35)] hover:text-dark dark:hover:text-[rgba(255,255,255,0.9)]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.4 19.54C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
          </svg>
        </a>
        <a href={`${lp}rss.xml`} aria-label="RSS" class="flex transition-colors duration-200 text-[rgba(0,0,0,0.4)] dark:text-[rgba(255,255,255,0.35)] hover:text-dark dark:hover:text-[rgba(255,255,255,0.9)]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"/>
            <path d="M4 4a16 16 0 0 1 16 16"/>
            <circle cx="5" cy="19" r="1"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</footer>
