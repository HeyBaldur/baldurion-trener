---
import type { Locale } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  locale: Locale;
  variant?: 'lime' | 'lilac';
}

const { locale, variant = 'lime' } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const lp = locale === 'en' ? base : `${base}${locale}/`;

const bgMap = {
  lime: 'bg-[var(--color-accent-lime)]',
  lilac: 'bg-[var(--color-accent-lilac)]',
};
---

<aside class:list={['rounded-3xl p-8 md:p-10 my-12', bgMap[variant]]}>
  <h2 class="font-display text-2xl md:text-3xl text-black leading-tight mb-3" style="font-family: var(--font-display);">
    {t.cta.coachingTitle.toUpperCase()}
  </h2>
  <p class="text-black/70 mb-6 max-w-prose">{t.cta.coachingBody}</p>
  <a
    href={`${lp}coaching/`}
    class="inline-flex items-center gap-2 bg-black text-white font-bold px-6 py-3 rounded-full hover:opacity-80 transition-opacity duration-200"
  >
    {t.cta.coachingButton}
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
</aside>
