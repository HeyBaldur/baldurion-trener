---
interface Props {
  t: {
    ratingText: string;
    titleLine1: string;
    titleLine2: string;
    subtitle: string;
    ctaText: string;
    ctaByline: string;
    ctaBylineRole: string;
    chatPillTop: string;
    chatTime: string;
    chatBubble1: string;
    chatBubble2: string;
    chatBubble3: string;
  };
}

const { t } = Astro.props;
const calendlyUrl = "https://calendly.com/smart-gym-app-assistance/30min";
---

<section
  class="relative max-w-[1400px] mx-auto mt-6 rounded-3xl overflow-hidden bg-[#0A0A0A] h-[600px] max-[1024px]:h-auto max-[1024px]:min-h-[520px] max-[768px]:min-h-[500px]"
>
  <!-- Background photo -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1600&q=80"
      alt="Lorem ipsum placeholder"
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 z-[1] bg-gradient-to-r from-black/95 via-black/70 to-transparent max-[768px]:bg-gradient-to-b max-[768px]:from-black/85 max-[768px]:to-black/60"
  >
  </div>

  <!-- Content -->
  <div
    class="relative z-[2] flex flex-col justify-center h-full max-w-[50%] px-14 py-16 max-[1024px]:max-w-[65%] max-[768px]:max-w-full max-[768px]:px-8 max-[768px]:py-12"
  >
    <!-- Title -->
    <h1
      class="text-[56px] leading-[1.05] font-bold tracking-[-0.02em] text-[#FAFAF7] mb-6 max-[768px]:text-[36px]"
      style="font-family: var(--font-display);"
    >
      {t.titleLine1}<br />
      {t.titleLine2}
    </h1>

    <!-- Subtitle -->
    <p
      class="text-base leading-relaxed text-white/70 max-w-[480px] mb-10"
      style="font-family: var(--font-body);"
    >
      {t.subtitle}
    </p>

    <!-- CTA button -->
    <a
      href={calendlyUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2.5 bg-[#D4E84A] text-[#0A0A0A] py-4 px-7 rounded-full font-bold text-[15px] no-underline w-fit mb-4 transition-transform duration-200 hover:-translate-y-0.5"
      style="font-family: var(--font-body);"
    >
      <span
        class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#0A0A0A] text-[#D4E84A] text-xs shrink-0"
        >▶</span
      >
      {t.ctaText}
    </a>

    <!-- CTA byline -->
    <div class="text-xs text-white/50" style="font-family: var(--font-body);">
      {t.ctaByline}<span class="text-[#D4E84A] mx-1">●</span>{t.ctaBylineRole}
    </div>
  </div>
</section>
