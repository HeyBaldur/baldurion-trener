---
interface Props {
  t: {
    eyebrow: string;
    titleLine1: string;
    titleLine2: string;
    subtitle: string;
    ctaPrimary: string;
    ctaSecondary: string;
    badgeTop: string;
    badgeBottom: string;
    stat1Value: string;
    stat1Label: string;
    stat2Value: string;
    stat2Label: string;
    stat3Value: string;
    stat3Label: string;
  };
  base: string;
  locale: string;
}

const { t, base, locale } = Astro.props;
const calendlyUrl = "https://calendly.com/smart-gym-app-assistance/30min";
const lp = locale === "en" ? base : `${base}${locale}/`;
const heroImg = `${base}images/brand/banner.jpg`;
---

<section
  class="relative min-h-[calc(100vh-4rem)] bg-dark flex items-stretch overflow-hidden"
>
  <!-- Photo side -->
  <div class="absolute inset-0 lg:left-[55%]">
    <img
      src={heroImg}
      alt="Rudolf Jaubert entrenando"
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      width="900"
      height="1200"
    />
    <!-- gradient blending left edge into dark bg on desktop -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-dark via-dark/60 to-dark/10 lg:via-dark/40 lg:to-transparent"
    >
    </div>
    <!-- gradient blending bottom on mobile -->
    <div
      class="absolute inset-0 bg-gradient-to-t from-dark via-dark/50 to-transparent lg:hidden"
    >
    </div>
    <!-- photo bottom fade into dark section below -->
    <div
      class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-b from-transparent to-dark pointer-events-none"
    >
    </div>
  </div>

  <!-- Content -->
  <div
    class="relative z-10 w-full max-w-[1280px] mx-auto px-6 py-12 lg:px-12 lg:py-0 flex flex-col justify-center lg:max-w-[55%] lg:mx-0 lg:ml-[max(3rem,calc((100vw-1280px)/2+3rem))]"
  >
    <!-- Eyebrow -->
    <p class="text-lime text-[11px] font-bold tracking-[0.3em] uppercase mb-6">
      {t.eyebrow}
    </p>

    <!-- Headline -->
    <h1
      class="text-light font-bold text-[clamp(2rem,5.5vw,4rem)] leading-[1.05] tracking-tight mb-6"
    >
      {t.titleLine1}<br />{t.titleLine2}
    </h1>

    <!-- Subtitle -->
    <p class="text-light/70 text-[17px] leading-[1.65] max-w-[480px] mb-10">
      {t.subtitle}
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-3 mb-10">
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-lime text-dark font-bold text-[14px] tracking-[0.03em] uppercase px-7 py-4 rounded-full no-underline transition-transform duration-200 hover:-translate-y-0.5"
      >
        {t.ctaPrimary}
      </a>
      <a
        href={`${lp}coaching/#metodo`}
        class="inline-flex items-center gap-2 text-light/80 font-semibold text-[14px] no-underline border border-light/20 px-7 py-4 rounded-full transition-colors duration-200 hover:border-lime/60 hover:text-lime"
      >
        {t.ctaSecondary}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap gap-x-6 gap-y-3">
      {
        [
          { value: t.stat1Value, label: t.stat1Label },
          { value: t.stat2Value, label: t.stat2Label },
          { value: t.stat3Value, label: t.stat3Label },
        ].map((stat, i) => (
          <div class="flex items-center gap-3">
            {i > 0 && (
              <span class="text-light/20 hidden sm:block" aria-hidden="true">
                |
              </span>
            )}
            <div>
              <div class="text-light font-bold text-[15px] leading-none">
                {stat.value}
              </div>
              <div class="text-light/50 text-[11px] mt-1">{stat.label}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
