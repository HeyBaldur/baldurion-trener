---
import type { Locale } from '../i18n/index';
import AboutTrayectoriaGallery from './AboutTrayectoriaGallery.astro';

interface Props {
  t: {
    heroTitle: string;
    heroSubtitle: string;
    photoAlt: string;
    body: {
      lead: string;
      paragraphs: string[];
    };
    gallery: {
      sectionEyebrow: string;
      sectionTitleStart: string;
      sectionTitleEm: string;
      photos: {
        patada: { title: string; meta: string };
        kungfu: { title: string; meta: string };
        coach: { title: string; meta: string };
        sparring: { title: string; meta: string };
        certificado: { title: string; meta: string };
      };
    };
    cta: {
      eyebrow: string;
      title: string;
      subtitle: string;
      primaryAction: string;
      secondaryAction: string;
    };
  };
  locale: Locale;
}

const { t, locale } = Astro.props;
const prefix = locale === 'en' ? '' : `/${locale}`;
---

<div class="about-page">

  <section class="about-hero">
    <div class="about-hero__shape"></div>
    <div class="about-hero__shape-pattern"></div>
    <div class="about-hero__content">
      <h1 class="about-hero__title" set:html={t.heroTitle} />
      <p class="about-hero__subtitle">{t.heroSubtitle}</p>
    </div>
    <img
      class="about-hero__photo"
      src="/images/about/rudolf-cutout.png"
      alt={t.photoAlt}
      loading="eager"
      fetchpriority="high"
    />
  </section>

  <section class="about-body">
    <p class="about-body__lead">{t.body.lead}</p>
    {t.body.paragraphs.map((paragraph) => (
      <p set:html={paragraph} />
    ))}
  </section>

  <AboutTrayectoriaGallery t={t.gallery} />

  <section class="about-cta">
    <div class="about-cta__text">
      <div class="about-cta__eyebrow">{t.cta.eyebrow.toUpperCase()}</div>
      <h2 class="about-cta__title">{t.cta.title}</h2>
      <p class="about-cta__subtitle">{t.cta.subtitle}</p>
    </div>
    <div class="about-cta__actions">
      <a href={`${prefix}/coaching/`} class="btn-dark rounded-full">{t.cta.primaryAction}</a>
      <a href={`${prefix}/contacto/`} class="btn-outline-dark rounded-full">{t.cta.secondaryAction}</a>
    </div>
  </section>

</div>

<style>
  /* ── Page wrapper ── */
  .about-page {
    padding: 48px 24px 96px;
  }
  @media (max-width: 640px) {
    .about-page { padding: 32px 16px 72px; }
  }

  /* ── Hero ── */
  .about-hero {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    border-radius: 24px;
    overflow: hidden;
    min-height: 600px;
  }
  :global([data-theme="dark"]) .about-hero {
    background: #0A0A0A;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  :global([data-theme="light"]) .about-hero {
    background: #FAFAF7;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .about-hero__shape {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 60%;
    background: #D4E84A;
    z-index: 1;
    clip-path: polygon(35% 0, 100% 0, 100% 100%, 5% 100%);
  }

  .about-hero__shape-pattern {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 60%;
    z-index: 2;
    clip-path: polygon(35% 0, 100% 0, 100% 100%, 5% 100%);
    background-image: linear-gradient(
      135deg,
      transparent 49%,
      rgba(10, 10, 10, 0.06) 49%,
      rgba(10, 10, 10, 0.06) 50%,
      transparent 50%
    );
    background-size: 80px 80px;
    pointer-events: none;
  }

  .about-hero__content {
    position: relative;
    z-index: 3;
    padding: 96px 64px;
    max-width: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 600px;
  }

  .about-hero__title {
    font-family: var(--font-display);
    font-size: 80px;
    line-height: 0.95;
    margin: 0 0 28px;
    text-transform: uppercase;
  }
  :global([data-theme="dark"]) .about-hero__title { color: #FFFFFF; }
  :global([data-theme="light"]) .about-hero__title { color: #0A0A0A; }

  /* .accent spans injected via set:html — targeted as descendants */
  .about-hero__title :global(.accent) { color: #D4E84A; }
  :global([data-theme="light"]) .about-hero__title :global(.accent) { color: #0A0A0A; }

  .about-hero__subtitle {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    max-width: 480px;
    margin: 0;
  }
  :global([data-theme="dark"]) .about-hero__subtitle { color: #CCCCCC; }
  :global([data-theme="light"]) .about-hero__subtitle { color: #555555; }

  .about-hero__photo {
    position: absolute;
    right: 5%;
    bottom: 0;
    height: 110%;
    z-index: 4;
    object-fit: contain;
    object-position: bottom center;
    width: auto;
    filter: drop-shadow(-20px 30px 40px rgba(0, 0, 0, 0.4));
  }

  @media (max-width: 900px) {
    .about-hero { min-height: 0; }

    .about-hero__shape,
    .about-hero__shape-pattern {
      top: auto;
      bottom: 0;
      right: 0;
      width: 100%;
      height: 50%;
      clip-path: polygon(0 30%, 100% 0, 100% 100%, 0 100%);
    }

    .about-hero__content {
      max-width: 100%;
      padding: 48px 32px 0;
      min-height: 0;
    }

    .about-hero__title { font-size: 48px; }

    .about-hero__photo {
      position: relative;
      height: 460px;
      right: auto;
      max-width: 100%;
      margin: 24px auto 0;
      display: block;
      filter: drop-shadow(-12px 20px 28px rgba(0, 0, 0, 0.35));
    }
  }

  @media (max-width: 640px) {
    .about-hero__title { font-size: 36px; }
    .about-hero__content { padding: 32px 24px 0; }
    .about-hero__photo { height: 360px; }
  }

  /* ── Body ── */
  .about-body {
    max-width: 760px;
    margin: 80px auto 0;
    padding: 0 32px;
  }

  .about-body__lead {
    font-family: var(--font-display);
    font-size: 32px;
    line-height: 1.15;
    padding-left: 20px;
    border-left: 3px solid #D4E84A;
    margin: 0 0 40px;
  }
  :global([data-theme="dark"]) .about-body__lead { color: #FFFFFF; }
  :global([data-theme="light"]) .about-body__lead { color: #0A0A0A; }

  .about-body p:not(.about-body__lead) {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.75;
    margin: 0 0 24px;
  }
  :global([data-theme="dark"]) .about-body p:not(.about-body__lead) { color: #CCCCCC; }
  :global([data-theme="light"]) .about-body p:not(.about-body__lead) { color: #555555; }

  /* <strong> tags injected via set:html */
  .about-body :global(strong) { font-weight: 700; }
  :global([data-theme="dark"]) .about-body :global(strong) { color: #D4E84A; }
  :global([data-theme="light"]) .about-body :global(strong) { color: #0A0A0A; }

  @media (max-width: 640px) {
    .about-body { margin-top: 56px; padding: 0 16px; }
    .about-body__lead { font-size: 26px; }
    .about-body p:not(.about-body__lead) { font-size: 17px; }
  }

  /* ── CTA ── */
  .about-cta {
    max-width: 1280px;
    margin: 80px auto 0;
    padding: 56px;
    background: linear-gradient(135deg, #D4E84A 0%, #C5D944 100%);
    border-radius: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
  }

  .about-cta__text { color: #0A0A0A; }

  .about-cta__eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin: 0 0 12px;
  }

  .about-cta__title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1;
    color: #0A0A0A;
    margin: 0 0 12px;
  }

  .about-cta__subtitle {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.5;
    font-weight: 500;
    color: #0A0A0A;
    margin: 0;
    max-width: 540px;
  }

  .about-cta__actions {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
  }

  .btn-dark {
    background: #0A0A0A;
    color: #D4E84A;
    padding: 18px 32px;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    border: 2px solid #0A0A0A;
    transition: background 200ms, color 200ms;
  }
  .btn-dark:hover { background: transparent; color: #0A0A0A; }

  .btn-outline-dark {
    background: transparent;
    color: #0A0A0A;
    padding: 18px 32px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    border: 2px solid #0A0A0A;
    transition: background 200ms, color 200ms;
  }
  .btn-outline-dark:hover { background: #0A0A0A; color: #D4E84A; }

  @media (max-width: 900px) {
    .about-cta {
      flex-direction: column;
      align-items: stretch;
      padding: 40px 32px;
      margin-top: 56px;
    }
    .about-cta__title { font-size: 32px; }
    .about-cta__actions { flex-direction: column; }
    .btn-dark, .btn-outline-dark { text-align: center; }
  }

  @media (max-width: 640px) {
    .about-cta { padding: 32px 24px; }
  }
</style>
