---
import type { Locale } from '../i18n/index';
import AboutTrayectoriaGallery from './AboutTrayectoriaGallery.astro';

interface Props {
  t: {
    heroTitle: string;
    heroSubtitle: string;
    photoAlt: string;
    body: {
      lead: string;
      paragraphs: string[];
    };
    gallery: {
      sectionEyebrow: string;
      sectionTitleStart: string;
      sectionTitleEm: string;
      photos: {
        patada: { title: string; meta: string };
        kungfu: { title: string; meta: string };
        coach: { title: string; meta: string };
        sparring: { title: string; meta: string };
        certificado: { title: string; meta: string };
      };
    };
    cta: {
      eyebrow: string;
      title: string;
      subtitle: string;
      primaryAction: string;
      secondaryAction: string;
    };
  };
  locale: Locale;
}

const { t, locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const lp = locale === 'en' ? base : `${base}${locale}/`;
---

<div class="px-[24px] pt-[48px] pb-[96px] max-[640px]:px-[16px] max-[640px]:pt-[32px] max-[640px]:pb-[72px]">

  <section class="relative max-w-[1280px] mx-auto rounded-[24px] overflow-hidden min-h-[600px] bg-light border border-[rgba(0,0,0,0.06)] dark:bg-dark dark:border-[rgba(255,255,255,0.06)] max-[900px]:min-h-0">

    <div
      class="about-shape absolute top-0 right-0 bottom-0 w-[60%] bg-lime z-[1] max-[900px]:top-auto max-[900px]:h-[50%] max-[900px]:w-full"
      style="clip-path: polygon(35% 0, 100% 0, 100% 100%, 5% 100%);"
    ></div>

    <div
      class="about-shape absolute top-0 right-0 bottom-0 w-[60%] z-[2] pointer-events-none max-[900px]:top-auto max-[900px]:h-[50%] max-[900px]:w-full"
      style="clip-path: polygon(35% 0, 100% 0, 100% 100%, 5% 100%); background-image: linear-gradient(135deg, transparent 49%, rgba(10,10,10,0.06) 49%, rgba(10,10,10,0.06) 50%, transparent 50%); background-size: 80px 80px;"
    ></div>

    <div class="relative z-[3] px-[64px] py-[96px] max-w-[50%] flex flex-col justify-center min-h-[600px] max-[900px]:max-w-full max-[900px]:px-[32px] max-[900px]:pt-[48px] max-[900px]:pb-0 max-[900px]:min-h-0 max-[640px]:px-[24px] max-[640px]:pt-[32px]">
      <h1
        class="font-display text-[80px] leading-[0.95] mt-0 mb-[28px] uppercase text-dark dark:text-white [&_.accent]:text-dark dark:[&_.accent]:text-lime max-[900px]:text-[48px] max-[640px]:text-[36px]"
        set:html={t.heroTitle}
      />
      <p class="font-body text-[17px] leading-[1.6] max-w-[480px] m-0 text-[#555555] dark:text-[#CCCCCC]">
        {t.heroSubtitle}
      </p>
    </div>

    <img
      class="absolute right-[5%] bottom-0 h-[110%] z-[4] object-contain object-bottom w-auto max-[900px]:static max-[900px]:h-[460px] max-[900px]:max-w-full max-[900px]:mx-auto max-[900px]:mt-[24px] max-[900px]:block max-[640px]:h-[360px]"
      src={`${base}images/about/rudolf-cutout.png`}
      alt={t.photoAlt}
      loading="eager"
      fetchpriority="high"
      style="filter: drop-shadow(-20px 30px 40px rgba(0,0,0,0.4));"
    />
  </section>

  <section class="max-w-[760px] mx-auto mt-[80px] px-[32px] max-[640px]:mt-[56px] max-[640px]:px-[16px]">
    <p
      class="font-display text-[32px] leading-[1.15] pl-[20px] border-l-[3px] border-lime mt-0 mb-[40px] text-dark dark:text-white max-[640px]:text-[26px]"
    >
      {t.body.lead}
    </p>
    {t.body.paragraphs.map((paragraph) => (
      <p
        class="font-body text-[18px] leading-[1.75] mt-0 mb-[24px] text-[#555555] dark:text-[#CCCCCC] [&_strong]:font-bold [&_strong]:text-dark dark:[&_strong]:text-lime max-[640px]:text-[17px]"
        set:html={paragraph}
      />
    ))}
  </section>

  <AboutTrayectoriaGallery t={t.gallery} />

  <section
    class="max-w-[1280px] mx-auto mt-[80px] p-[56px] rounded-[24px] flex justify-between items-center gap-[32px] max-[900px]:flex-col max-[900px]:items-stretch max-[900px]:p-[40px_32px] max-[900px]:mt-[56px] max-[640px]:p-[32px_24px]"
    style="background: linear-gradient(135deg, #D4E84A 0%, #C5D944 100%);"
  >
    <div>
      <div class="font-body text-[11px] font-extrabold tracking-[0.3em] uppercase mt-0 mb-[12px] text-dark">
        {t.cta.eyebrow.toUpperCase()}
      </div>
      <h2 class="font-display text-[44px] leading-[1] text-dark mt-0 mb-[12px] max-[900px]:text-[32px]">
        {t.cta.title}
      </h2>
      <p class="font-body text-[16px] leading-[1.5] font-medium text-dark m-0 max-w-[540px]">
        {t.cta.subtitle}
      </p>
    </div>
    <div class="flex gap-[12px] shrink-0 max-[900px]:flex-col">
      <a
        href={`${lp}coaching/`}
        class="font-body rounded-full bg-dark text-lime px-[32px] py-[18px] font-extrabold text-[13px] tracking-[0.05em] uppercase no-underline border-2 border-dark transition-[background,color] duration-200 whitespace-nowrap text-center hover:bg-transparent hover:text-dark"
      >
        {t.cta.primaryAction}
      </a>
      <a
        href={`${lp}contacto/`}
        class="font-body rounded-full bg-transparent text-dark px-[32px] py-[18px] font-bold text-[13px] tracking-[0.05em] uppercase no-underline border-2 border-dark transition-[background,color] duration-200 whitespace-nowrap text-center hover:bg-dark hover:text-lime"
      >
        {t.cta.secondaryAction}
      </a>
    </div>
  </section>

</div>

<style is:global>
  /* clip-path responsive override for hero shape divs — no Tailwind equivalent */
  @media (max-width: 900px) {
    .about-shape {
      clip-path: polygon(0 30%, 100% 0, 100% 100%, 0 100%) !important;
    }
  }
</style>
