---
interface Props {
  t: {
    metaTitle: string;
    metaDescription: string;
    hero: {
      pretitle: string;
      titleLine1: string;
      titleEmphasis: string;
      subtitle: string;
      ctaPrimary: string;
      ctaSecondary: string;
      bottomMetaTitle: string;
      bottomMetaText: string;
      bgTextLeft: string;
      bgTextRight: string;
    };
    audience: {
      sectionEyebrow: string;
      sectionTitle: string;
      sectionSubtitle: string;
      yesTitle: string;
      noTitle: string;
      yesItems: string[];
      noItems: string[];
    };
    method: {
      sectionEyebrow: string;
      sectionTitle: string;
      sectionSubtitle: string;
      phases: Array<{
        number: string;
        label: string;
        title: string;
        duration: string;
        description: string;
        items: string[];
      }>;
    };
    levels: {
      sectionEyebrow: string;
      sectionTitle: string;
      sectionSubtitle: string;
      items: Array<{ name: string; description: string }>;
    };
    modalities: {
      sectionEyebrow: string;
      sectionTitle: string;
      online: { badge: string; title: string; location: string; features: string[] };
      onsite: { badge: string; title: string; location: string; features: string[] };
    };
    investment: { title: string; text: string; detail: string };
    ctaFinal: { eyebrow: string; title: string; subtitle: string; button: string };
  };
  locale: 'es' | 'en' | 'pl';
}

const { t } = Astro.props;
const calendlyUrl = 'https://calendly.com/smart-gym-app-assistance/30min';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const sEyebrow = "inline-block text-[11px] font-bold tracking-[0.3em] uppercase mb-[16px] text-[#444] dark:text-[#D4E84A]";
const sTitle = "text-[56px] leading-[0.95] mb-[16px] mt-0 uppercase text-[#0A0A0A] dark:text-[#FAFAF7] max-[768px]:text-[40px]";
const sSub = "text-[17px] leading-[1.6] m-0 text-[#555] dark:text-[#999]";
const sHeader = "mb-[48px] text-center max-w-[720px] mx-auto";

const levelNameColors = [
  "text-[#aaa] dark:text-[#666]",
  "text-[#777] dark:text-[#999]",
  "text-[#0A0A0A] dark:text-[#D4E84A]",
  "text-[#0A0A0A] dark:text-[#D4E84A]",
];
---

<!-- ===== AUDIENCE ===== -->
<section class="max-w-[1280px] mx-auto mb-[80px] px-[32px] max-[768px]:px-[16px] mt-[80px] max-[768px]:mt-[40px]">
  <div class={sHeader}>
    <span class={sEyebrow} style="font-family: var(--font-body);">{t.audience.sectionEyebrow}</span>
    <h2 class={sTitle} style="font-family: var(--font-display);">{t.audience.sectionTitle}</h2>
    <p class={sSub} style="font-family: var(--font-body);">{t.audience.sectionSubtitle}</p>
  </div>

  <div class="grid grid-cols-2 gap-[32px] max-[1024px]:grid-cols-1">

    <div class="rounded-[24px] p-[40px] border border-[rgba(212,232,74,0.4)] dark:border-[rgba(212,232,74,0.3)]" style="background: linear-gradient(135deg, rgba(212,232,74,0.07) 0%, rgba(212,232,74,0) 100%);">
      <h3
        class="text-[36px] leading-[1] mb-[32px] mt-0 uppercase text-[#0A0A0A] dark:text-[#D4E84A]"
        style="font-family: var(--font-display);"
      >{t.audience.yesTitle}</h3>
      <ul class="list-none flex flex-col gap-[20px] p-0 m-0">
        {t.audience.yesItems.map((item) => (
          <li class="flex gap-[16px] items-start">
            <div class="shrink-0 w-[32px] h-[32px] rounded-full bg-[#D4E84A] text-[#0A0A0A] flex items-center justify-center text-[16px] font-extrabold">✓</div>
            <p
              class="text-[16px] leading-[1.5] text-[#333] dark:text-[#E0E0E0] pt-[4px] m-0 [&_strong]:font-bold [&_strong]:text-[#0A0A0A] dark:[&_strong]:text-[#D4E84A]"
              style="font-family: var(--font-body);"
              set:html={item}
            />
          </li>
        ))}
      </ul>
    </div>

    <div class="rounded-[24px] p-[40px] bg-[#f5f5f0] dark:bg-[#141414] border border-[rgba(0,0,0,0.08)] dark:border-[rgba(255,255,255,0.08)]">
      <h3
        class="text-[36px] leading-[1] mb-[32px] mt-0 uppercase text-[#777] dark:text-[#888]"
        style="font-family: var(--font-display);"
      >{t.audience.noTitle}</h3>
      <ul class="list-none flex flex-col gap-[20px] p-0 m-0">
        {t.audience.noItems.map((item) => (
          <li class="flex gap-[16px] items-start">
            <div class="shrink-0 w-[32px] h-[32px] rounded-full bg-[rgba(0,0,0,0.06)] dark:bg-[rgba(255,255,255,0.06)] text-[#999] dark:text-[#666] flex items-center justify-center text-[16px] font-extrabold">✕</div>
            <p
              class="text-[16px] leading-[1.5] text-[#666] dark:text-[#888] pt-[4px] m-0"
              style="font-family: var(--font-body);"
              set:html={item}
            />
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<!-- ===== METHOD ===== -->
<section id="metodo" class="max-w-[1280px] mx-auto mb-[80px] px-[32px] max-[768px]:px-[16px]">
  <div class={sHeader}>
    <span class={sEyebrow} style="font-family: var(--font-body);">{t.method.sectionEyebrow}</span>
    <h2 class={sTitle} style="font-family: var(--font-display);">{t.method.sectionTitle}</h2>
    <p class={sSub} style="font-family: var(--font-body);">{t.method.sectionSubtitle}</p>
  </div>

  <div class="grid grid-cols-4 gap-[16px] max-[1024px]:grid-cols-2 max-[768px]:grid-cols-1">
    {t.method.phases.map((phase) => (
      <div class="bg-[#f5f5f0] dark:bg-[#141414] border border-[rgba(0,0,0,0.08)] dark:border-[rgba(255,255,255,0.08)] rounded-[20px] p-[32px_28px] relative overflow-hidden">
        <div
          class="absolute top-[24px] right-[24px] text-[rgba(0,0,0,0.05)] dark:text-[rgba(212,232,74,0.08)] z-0 leading-[1]"
          style="font-family: var(--font-display); font-size: 80px;"
          aria-hidden="true"
        >{phase.number}</div>

        <span
          class="relative z-[1] inline-block text-[10px] font-bold tracking-[0.3em] uppercase mb-[16px] px-[10px] py-[4px] border rounded-full text-[#444] border-[rgba(0,0,0,0.15)] bg-[rgba(0,0,0,0.04)] dark:text-[#D4E84A] dark:border-[rgba(212,232,74,0.3)] dark:bg-[rgba(212,232,74,0.05)]"
          style="font-family: var(--font-body);"
        >{phase.label}</span>

        <h3
          class="relative z-[1] text-[32px] leading-[1] mb-[12px] mt-0 uppercase text-[#0A0A0A] dark:text-[#FAFAF7]"
          style="font-family: var(--font-display);"
        >{phase.title}</h3>

        <div
          class="relative z-[1] text-[12px] text-[#444] dark:text-[#D4E84A] font-bold mb-[16px] tracking-[0.1em]"
          style="font-family: var(--font-body);"
        >{phase.duration}</div>

        <p
          class="relative z-[1] text-[14px] leading-[1.6] text-[#666] dark:text-[#999] mb-[16px] mt-0"
          style="font-family: var(--font-body);"
        >{phase.description}</p>

        <ul class="relative z-[1] list-none flex flex-col gap-[8px] p-0 m-0">
          {phase.items.map((item) => (
            <li class="flex gap-[8px] text-[13px] leading-[1.5] text-[#666] dark:text-[#999]" style="font-family: var(--font-body);">
              <span class="text-[#444] dark:text-[#D4E84A] font-bold shrink-0">→</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<!-- ===== LEVELS ===== -->
<section class="max-w-[1280px] mx-auto mb-[80px] px-[32px] max-[768px]:px-[16px]">
  <div class={sHeader}>
    <span class={sEyebrow} style="font-family: var(--font-body);">{t.levels.sectionEyebrow}</span>
    <h2 class={sTitle} style="font-family: var(--font-display);">{t.levels.sectionTitle}</h2>
    <p class={sSub} style="font-family: var(--font-body);">{t.levels.sectionSubtitle}</p>
  </div>

  <div class="grid grid-cols-4 gap-[16px] max-[1024px]:grid-cols-2 max-[768px]:grid-cols-1">
    {t.levels.items.map((level, idx) => (
      <div class="bg-[#f5f5f0] dark:bg-[#141414] border border-[rgba(0,0,0,0.08)] dark:border-[rgba(255,255,255,0.08)] rounded-[20px] p-[32px_24px]">
        <h3
          class={`text-[28px] leading-[1] mb-[12px] mt-0 uppercase ${levelNameColors[idx] ?? levelNameColors[3]}`}
          style="font-family: var(--font-display);"
        >{level.name}</h3>
        <p class="text-[14px] leading-[1.6] text-[#666] dark:text-[#999] m-0" style="font-family: var(--font-body);">{level.description}</p>
      </div>
    ))}
  </div>
</section>

<!-- ===== MODALITIES ===== -->
<section class="max-w-[1280px] mx-auto mb-[80px] px-[32px] grid grid-cols-2 gap-[24px] max-[1024px]:grid-cols-1 max-[768px]:px-[16px]">
  {[t.modalities.online, t.modalities.onsite].map((mod) => (
    <div class="bg-[#f5f5f0] dark:bg-[#141414] border border-[rgba(0,0,0,0.08)] dark:border-[rgba(255,255,255,0.08)] rounded-[24px] p-[40px]">
      <span
        class="inline-block text-[10px] font-bold tracking-[0.25em] uppercase mb-[16px] px-[10px] py-[4px] border rounded-full text-[#444] border-[rgba(0,0,0,0.15)] bg-[rgba(0,0,0,0.04)] dark:text-[#D4E84A] dark:border-[rgba(212,232,74,0.3)] dark:bg-[rgba(212,232,74,0.05)]"
        style="font-family: var(--font-body);"
      >{mod.badge}</span>
      <h3
        class="text-[36px] leading-[1] mb-[12px] mt-0 uppercase text-[#0A0A0A] dark:text-[#FAFAF7]"
        style="font-family: var(--font-display);"
      >{mod.title}</h3>
      <p class="text-[13px] text-[#777] dark:text-[#888] mb-[24px] mt-0 tracking-[0.05em]" style="font-family: var(--font-body);">{mod.location}</p>
      <ul class="list-none flex flex-col gap-[12px] p-0 m-0">
        {mod.features.map((f) => (
          <li class="flex gap-[10px] text-[14px] leading-[1.5] text-[#333] dark:text-[#E0E0E0]" style="font-family: var(--font-body);">
            <span class="text-[#0A0A0A] dark:text-[#D4E84A] font-extrabold shrink-0">✓</span>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>
  ))}
</section>

<!-- ===== INVESTMENT ===== -->
<section class="max-w-[1280px] mx-auto mb-[80px] px-[48px] py-[64px] bg-[#f5f5f0] dark:bg-[#141414] border border-[rgba(0,0,0,0.08)] dark:border-[rgba(255,255,255,0.08)] rounded-[24px] text-center max-[768px]:px-[24px] max-[768px]:py-[40px]">
  <h2
    class="text-[48px] leading-[1] mb-[24px] mt-0 uppercase text-[#0A0A0A] dark:text-[#FAFAF7]"
    style="font-family: var(--font-display);"
  >{t.investment.title}</h2>
  <p
    class="text-[17px] leading-[1.7] text-[#555] dark:text-[#999] max-w-[640px] mx-auto mb-[16px] mt-0 [&_strong]:font-bold [&_strong]:text-[#0A0A0A] dark:[&_strong]:text-[#D4E84A]"
    style="font-family: var(--font-body);"
    set:html={t.investment.text}
  />
  <p class="text-[14px] text-[#888] dark:text-[#666] max-w-[640px] mx-auto m-0" style="font-family: var(--font-body);">{t.investment.detail}</p>
</section>

<!-- ===== CTA FINAL ===== -->
<section
  class="max-w-[1280px] mx-auto mb-[80px] p-[56px] rounded-[24px] flex justify-between items-center gap-[32px] max-[768px]:flex-col max-[768px]:items-stretch max-[768px]:text-left max-[768px]:p-[40px_32px] max-[768px]:mx-[16px]"
  style="background: linear-gradient(135deg, #D4E84A 0%, #C5D944 100%);"
>
  <div>
    <div class="text-[11px] font-extrabold tracking-[0.3em] uppercase mb-[12px] text-[#0A0A0A]" style="font-family: var(--font-body);">
      {t.ctaFinal.eyebrow}
    </div>
    <h2
      class="text-[44px] leading-[1] mb-[12px] mt-0 uppercase text-[#0A0A0A] max-[768px]:text-[32px]"
      style="font-family: var(--font-display);"
    >{t.ctaFinal.title}</h2>
    <p class="text-[16px] leading-[1.5] font-medium text-[#0A0A0A] m-0 max-w-[540px]" style="font-family: var(--font-body);">{t.ctaFinal.subtitle}</p>
  </div>
  <a
    href={calendlyUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="rounded-full bg-[#0A0A0A] text-[#D4E84A] px-[40px] py-[20px] font-extrabold text-[14px] tracking-[0.05em] uppercase no-underline whitespace-nowrap border-2 border-[#0A0A0A] shrink-0 transition-all duration-200 text-center hover:bg-transparent hover:text-[#0A0A0A] max-[768px]:text-center"
    style="font-family: var(--font-body);"
  >
    {t.ctaFinal.button}
  </a>
</section>

<style is:global>
  /* Hero: bg dark mode (gradient, no Tailwind bg-[] equivalent) */
  [data-theme="dark"] [data-coaching-hero] {
    background: linear-gradient(135deg, #1a1a1a 0%, #050505 100%) !important;
  }

  /* Hero photo area — responsive position/size changes */
  .hero-photo-area {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 50%;
    overflow: hidden;
    z-index: 1;
  }
  @media (max-width: 1024px) {
    .hero-photo-area { width: 40%; }
  }
  @media (max-width: 768px) {
    .hero-photo-area {
      position: relative;
      width: 100%;
      height: 280px;
      top: auto; right: auto; bottom: auto;
    }
  }

  /* Hero photo overlay — gradient changes direction + color at mobile */
  .hero-photo-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(90deg, #fafaf7 0%, transparent 40%);
  }
  [data-theme="dark"] .hero-photo-overlay {
    background: linear-gradient(90deg, #0a0a0a 0%, transparent 40%);
  }
  @media (max-width: 768px) {
    .hero-photo-overlay {
      background: linear-gradient(180deg, transparent 0%, #fafaf7 100%);
    }
    [data-theme="dark"] .hero-photo-overlay {
      background: linear-gradient(180deg, transparent 0%, #0a0a0a 100%);
    }
  }
</style>
