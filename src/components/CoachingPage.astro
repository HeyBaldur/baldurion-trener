---
interface Props {
  t: {
    metaTitle: string;
    metaDescription: string;
    hero: {
      pretitle: string;
      titleLine1: string;
      titleEmphasis: string;
      subtitle: string;
      ctaPrimary: string;
      ctaSecondary: string;
      bottomMetaTitle: string;
      bottomMetaText: string;
      bgTextLeft: string;
      bgTextRight: string;
    };
    audience: {
      sectionEyebrow: string;
      sectionTitle: string;
      sectionSubtitle: string;
      yesTitle: string;
      noTitle: string;
      yesItems: string[];
      noItems: string[];
    };
    method: {
      sectionEyebrow: string;
      sectionTitle: string;
      sectionSubtitle: string;
      phases: Array<{
        number: string;
        label: string;
        title: string;
        duration: string;
        description: string;
        items: string[];
      }>;
    };
    levels: {
      sectionEyebrow: string;
      sectionTitle: string;
      sectionSubtitle: string;
      items: Array<{ name: string; description: string }>;
    };
    modalities: {
      sectionEyebrow: string;
      sectionTitle: string;
      online: { badge: string; title: string; location: string; features: string[] };
      onsite: { badge: string; title: string; location: string; features: string[] };
    };
    investment: { title: string; text: string; detail: string };
    ctaFinal: { eyebrow: string; title: string; subtitle: string; button: string };
  };
  locale: 'es' | 'en' | 'pl';
}

const { t } = Astro.props;
const calendlyUrl = 'https://calendly.com/smart-gym-app-assistance/30min';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<section class="coaching-hero">
  <div class="coaching-hero__bg-text coaching-hero__bg-text--top">{t.hero.bgTextLeft}</div>
  <div class="coaching-hero__bg-text coaching-hero__bg-text--bottom">{t.hero.bgTextRight}</div>

  <div class="coaching-hero__photo-area">
    <img
      src={`${base}images/coaching/placeholder-hero.jpg`}
      alt={t.hero.titleLine1}
      loading="eager"
      fetchpriority="high"
    />
    <div class="coaching-hero__photo-overlay"></div>
  </div>

  <div class="coaching-hero__content">
    <div class="coaching-hero__pretitle">{t.hero.pretitle}</div>

    <h1 class="coaching-hero__title">
      {t.hero.titleLine1}<br />
      <span class="coaching-hero__title-em">{t.hero.titleEmphasis}</span>
    </h1>

    <p class="coaching-hero__subtitle">{t.hero.subtitle}</p>

    <div class="coaching-hero__actions">
      <a href={calendlyUrl} target="_blank" rel="noopener noreferrer" class="btn-primary rounded-full">
        {t.hero.ctaPrimary}
      </a>
      <a href="#metodo" class="btn-secondary rounded-full">
        {t.hero.ctaSecondary}
      </a>
    </div>
  </div>

  <div class="coaching-hero__bottom-meta">
    <strong>{t.hero.bottomMetaTitle}</strong>
    <span>{t.hero.bottomMetaText}</span>
  </div>
</section>

<section class="coaching-audience-wrap">
  <div class="section-header">
    <span class="section-eyebrow">{t.audience.sectionEyebrow}</span>
    <h2 class="section-title">{t.audience.sectionTitle}</h2>
    <p class="section-subtitle">{t.audience.sectionSubtitle}</p>
  </div>

  <div class="coaching-audience">
    <div class="coaching-audience__column coaching-audience__column--positive">
      <h3 class="coaching-audience__column-title">{t.audience.yesTitle}</h3>
      <ul class="coaching-audience__list">
        {t.audience.yesItems.map((item) => (
          <li class="coaching-audience__item">
            <div class="coaching-audience__icon">✓</div>
            <p class="coaching-audience__text" set:html={item} />
          </li>
        ))}
      </ul>
    </div>

    <div class="coaching-audience__column coaching-audience__column--negative">
      <h3 class="coaching-audience__column-title">{t.audience.noTitle}</h3>
      <ul class="coaching-audience__list">
        {t.audience.noItems.map((item) => (
          <li class="coaching-audience__item">
            <div class="coaching-audience__icon">✕</div>
            <p class="coaching-audience__text" set:html={item} />
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section id="metodo" class="coaching-method">
  <div class="section-header">
    <span class="section-eyebrow">{t.method.sectionEyebrow}</span>
    <h2 class="section-title">{t.method.sectionTitle}</h2>
    <p class="section-subtitle">{t.method.sectionSubtitle}</p>
  </div>

  <div class="coaching-method__phases">
    {t.method.phases.map((phase) => (
      <div class="phase">
        <div class="phase__number">{phase.number}</div>
        <span class="phase__label">{phase.label}</span>
        <h3 class="phase__title">{phase.title}</h3>
        <div class="phase__duration">{phase.duration}</div>
        <p class="phase__description">{phase.description}</p>
        <ul class="phase__list">
          {phase.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>

<section class="coaching-levels">
  <div class="section-header">
    <span class="section-eyebrow">{t.levels.sectionEyebrow}</span>
    <h2 class="section-title">{t.levels.sectionTitle}</h2>
    <p class="section-subtitle">{t.levels.sectionSubtitle}</p>
  </div>

  <div class="coaching-levels__grid">
    {t.levels.items.map((level, idx) => (
      <div class={`level level--${idx + 1}`}>
        <h3 class="level__name">{level.name}</h3>
        <p class="level__description">{level.description}</p>
      </div>
    ))}
  </div>
</section>

<section class="coaching-modalities">
  <div class="modality">
    <span class="modality__badge">{t.modalities.online.badge}</span>
    <h3 class="modality__title">{t.modalities.online.title}</h3>
    <p class="modality__location">{t.modalities.online.location}</p>
    <ul class="modality__features">
      {t.modalities.online.features.map((f) => <li>{f}</li>)}
    </ul>
  </div>

  <div class="modality">
    <span class="modality__badge">{t.modalities.onsite.badge}</span>
    <h3 class="modality__title">{t.modalities.onsite.title}</h3>
    <p class="modality__location">{t.modalities.onsite.location}</p>
    <ul class="modality__features">
      {t.modalities.onsite.features.map((f) => <li>{f}</li>)}
    </ul>
  </div>
</section>

<section class="coaching-investment">
  <h2 class="coaching-investment__title">{t.investment.title}</h2>
  <p class="coaching-investment__text" set:html={t.investment.text} />
  <p class="coaching-investment__detail">{t.investment.detail}</p>
</section>

<section class="coaching-cta-final">
  <div class="coaching-cta-final__text">
    <div class="coaching-cta-final__eyebrow">{t.ctaFinal.eyebrow}</div>
    <h2 class="coaching-cta-final__title">{t.ctaFinal.title}</h2>
    <p class="coaching-cta-final__subtitle">{t.ctaFinal.subtitle}</p>
  </div>
  <a
    href={calendlyUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="coaching-cta-final__button rounded-full"
  >
    {t.ctaFinal.button}
  </a>
</section>

<style>
  /* ===== HERO ===== */
  .coaching-hero {
    max-width: 1280px;
    margin: 32px auto 80px;
    height: 600px;
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: flex-end;
    background: linear-gradient(135deg, #f5f5f0 0%, #fafaf7 100%);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="dark"]) .coaching-hero {
    background: linear-gradient(135deg, #1a1a1a 0%, #050505 100%);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .coaching-hero__bg-text {
    position: absolute;
    font-family: var(--font-display);
    font-size: 200px;
    color: rgba(212, 232, 74, 0.06);
    font-weight: 900;
    line-height: 0.85;
    user-select: none;
    pointer-events: none;
    text-transform: uppercase;
    z-index: 0;
  }

  :global([data-theme="light"]) .coaching-hero__bg-text {
    color: rgba(0, 0, 0, 0.04);
  }

  .coaching-hero__bg-text--top {
    top: -20px;
    right: 60px;
  }

  .coaching-hero__bg-text--bottom {
    top: 180px;
    right: -50px;
  }

  .coaching-hero__photo-area {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    overflow: hidden;
    z-index: 1;
  }

  .coaching-hero__photo-area img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .coaching-hero__photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, #fafaf7 0%, transparent 40%);
    pointer-events: none;
  }

  :global([data-theme="dark"]) .coaching-hero__photo-overlay {
    background: linear-gradient(90deg, #0a0a0a 0%, transparent 40%);
  }

  .coaching-hero__content {
    position: relative;
    z-index: 2;
    padding: 64px;
    max-width: 56%;
  }

  .coaching-hero__pretitle {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 24px;
  }

  :global([data-theme="dark"]) .coaching-hero__pretitle {
    color: #D4E84A;
  }

  .coaching-hero__pretitle::before {
    content: '';
    width: 32px;
    height: 1px;
    background: #444;
  }

  :global([data-theme="dark"]) .coaching-hero__pretitle::before {
    background: #D4E84A;
  }

  .coaching-hero__title {
    font-family: var(--font-display);
    font-size: 84px;
    line-height: 0.92;
    text-transform: uppercase;
    margin-bottom: 24px;
    color: #0a0a0a;
  }

  :global([data-theme="dark"]) .coaching-hero__title {
    color: #fafaf7;
  }

  .coaching-hero__title-em {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    text-transform: lowercase;
    color: #0a0a0a;
  }

  :global([data-theme="dark"]) .coaching-hero__title-em {
    color: #D4E84A;
  }

  .coaching-hero__subtitle {
    font-size: 16px;
    line-height: 1.6;
    color: #555;
    max-width: 420px;
    margin-bottom: 32px;
  }

  :global([data-theme="dark"]) .coaching-hero__subtitle {
    color: #ccc;
  }

  .coaching-hero__actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .coaching-hero__bottom-meta {
    position: absolute;
    bottom: 32px;
    right: 64px;
    font-size: 11px;
    color: #777;
    letter-spacing: 0.1em;
    z-index: 3;
    text-align: right;
  }

  :global([data-theme="dark"]) .coaching-hero__bottom-meta {
    color: #999;
  }

  .coaching-hero__bottom-meta strong {
    display: block;
    color: #0a0a0a;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 700;
    font-size: 12px;
  }

  :global([data-theme="dark"]) .coaching-hero__bottom-meta strong {
    color: #fafaf7;
  }

  /* ===== BUTTONS ===== */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #D4E84A;
    color: #0a0a0a;
    padding: 18px 32px;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid #D4E84A;
    transition: transform 200ms;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: #0a0a0a;
    padding: 18px 32px;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid rgba(0, 0, 0, 0.2);
    transition: all 200ms;
  }

  :global([data-theme="dark"]) .btn-secondary {
    color: #fafaf7;
    border-color: rgba(255, 255, 255, 0.2);
  }

  .btn-secondary:hover {
    border-color: #0a0a0a;
    background: rgba(0, 0, 0, 0.05);
  }

  :global([data-theme="dark"]) .btn-secondary:hover {
    border-color: #fafaf7;
    background: rgba(255, 255, 255, 0.05);
  }

  /* ===== SECTION HEADERS ===== */
  .section-header {
    margin-bottom: 48px;
    text-align: center;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 16px;
  }

  :global([data-theme="dark"]) .section-eyebrow {
    color: #D4E84A;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 56px;
    line-height: 0.95;
    margin-bottom: 16px;
    text-transform: uppercase;
    color: #0a0a0a;
  }

  :global([data-theme="dark"]) .section-title {
    color: #fafaf7;
  }

  .section-subtitle {
    font-size: 17px;
    line-height: 1.6;
    color: #555;
  }

  :global([data-theme="dark"]) .section-subtitle {
    color: #999;
  }

  /* ===== AUDIENCE ===== */
  .coaching-audience-wrap {
    max-width: 1280px;
    margin: 0 auto 80px;
    padding: 0 32px;
  }

  .coaching-audience {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .coaching-audience__column {
    background: #f5f5f0;
    border-radius: 24px;
    padding: 40px;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="dark"]) .coaching-audience__column {
    background: #141414;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .coaching-audience__column--positive {
    border-color: rgba(212, 232, 74, 0.4);
    background: linear-gradient(135deg, rgba(212, 232, 74, 0.07) 0%, rgba(212, 232, 74, 0) 100%);
  }

  :global([data-theme="dark"]) .coaching-audience__column--positive {
    border-color: rgba(212, 232, 74, 0.3);
    background: linear-gradient(135deg, rgba(212, 232, 74, 0.04) 0%, rgba(212, 232, 74, 0) 100%);
  }

  .coaching-audience__column-title {
    font-family: var(--font-display);
    font-size: 36px;
    line-height: 1;
    margin-bottom: 32px;
    text-transform: uppercase;
  }

  .coaching-audience__column--positive .coaching-audience__column-title {
    color: #0a0a0a;
  }

  :global([data-theme="dark"]) .coaching-audience__column--positive .coaching-audience__column-title {
    color: #D4E84A;
  }

  .coaching-audience__column--negative .coaching-audience__column-title {
    color: #777;
  }

  :global([data-theme="dark"]) .coaching-audience__column--negative .coaching-audience__column-title {
    color: #888;
  }

  .coaching-audience__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 0;
    margin: 0;
  }

  .coaching-audience__item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .coaching-audience__icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 800;
  }

  .coaching-audience__column--positive .coaching-audience__icon {
    background: #D4E84A;
    color: #0a0a0a;
  }

  .coaching-audience__column--negative .coaching-audience__icon {
    background: rgba(0, 0, 0, 0.06);
    color: #999;
  }

  :global([data-theme="dark"]) .coaching-audience__column--negative .coaching-audience__icon {
    background: rgba(255, 255, 255, 0.06);
    color: #666;
  }

  .coaching-audience__text {
    font-size: 16px;
    line-height: 1.5;
    color: #333;
    padding-top: 4px;
    margin: 0;
  }

  :global([data-theme="dark"]) .coaching-audience__text {
    color: #e0e0e0;
  }

  .coaching-audience__column--negative .coaching-audience__text {
    color: #666;
  }

  :global([data-theme="dark"]) .coaching-audience__column--negative .coaching-audience__text {
    color: #888;
  }

  .coaching-audience__text :global(strong) {
    color: #0a0a0a;
    font-weight: 700;
  }

  :global([data-theme="dark"]) .coaching-audience__text :global(strong) {
    color: #D4E84A;
  }

  /* ===== METHOD ===== */
  .coaching-method {
    max-width: 1280px;
    margin: 0 auto 80px;
    padding: 0 32px;
  }

  .coaching-method__phases {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .phase {
    background: #f5f5f0;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 20px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .phase {
    background: #141414;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .phase__number {
    position: absolute;
    top: 24px;
    right: 24px;
    font-family: var(--font-display);
    font-size: 80px;
    line-height: 1;
    color: rgba(0, 0, 0, 0.05);
    z-index: 0;
  }

  :global([data-theme="dark"]) .phase__number {
    color: rgba(212, 232, 74, 0.08);
  }

  .phase__label {
    position: relative;
    z-index: 1;
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #444;
    margin-bottom: 16px;
    padding: 4px 10px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 9999px;
    background: rgba(0, 0, 0, 0.04);
  }

  :global([data-theme="dark"]) .phase__label {
    color: #D4E84A;
    border-color: rgba(212, 232, 74, 0.3);
    background: rgba(212, 232, 74, 0.05);
  }

  .phase__title {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 32px;
    line-height: 1;
    margin-bottom: 12px;
    text-transform: uppercase;
    color: #0a0a0a;
  }

  :global([data-theme="dark"]) .phase__title {
    color: #fafaf7;
  }

  .phase__duration {
    position: relative;
    z-index: 1;
    font-size: 12px;
    color: #444;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: 0.1em;
  }

  :global([data-theme="dark"]) .phase__duration {
    color: #D4E84A;
  }

  .phase__description {
    position: relative;
    z-index: 1;
    font-size: 14px;
    line-height: 1.6;
    color: #666;
    margin-bottom: 16px;
  }

  :global([data-theme="dark"]) .phase__description {
    color: #999;
  }

  .phase__list {
    position: relative;
    z-index: 1;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0;
    margin: 0;
  }

  .phase__list li {
    font-size: 13px;
    line-height: 1.5;
    color: #666;
    padding-left: 16px;
    position: relative;
  }

  :global([data-theme="dark"]) .phase__list li {
    color: #999;
  }

  .phase__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #444;
    font-weight: 700;
  }

  :global([data-theme="dark"]) .phase__list li::before {
    color: #D4E84A;
  }

  /* ===== LEVELS ===== */
  .coaching-levels {
    max-width: 1280px;
    margin: 0 auto 80px;
    padding: 0 32px;
  }

  .coaching-levels__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .level {
    background: #f5f5f0;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 20px;
    padding: 32px 24px;
  }

  :global([data-theme="dark"]) .level {
    background: #141414;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .level__name {
    font-family: var(--font-display);
    font-size: 28px;
    line-height: 1;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .level--1 .level__name { color: #aaa; }
  .level--2 .level__name { color: #777; }
  .level--3 .level__name { color: #0a0a0a; }
  .level--4 .level__name { color: #0a0a0a; }

  :global([data-theme="dark"]) .level--1 .level__name { color: #666; }
  :global([data-theme="dark"]) .level--2 .level__name { color: #999; }
  :global([data-theme="dark"]) .level--3 .level__name { color: #D4E84A; }
  :global([data-theme="dark"]) .level--4 .level__name { color: #D4E84A; }

  .level__description {
    font-size: 14px;
    line-height: 1.6;
    color: #666;
    margin: 0;
  }

  :global([data-theme="dark"]) .level__description {
    color: #999;
  }

  /* ===== MODALITIES ===== */
  .coaching-modalities {
    max-width: 1280px;
    margin: 0 auto 80px;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .modality {
    background: #f5f5f0;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 24px;
    padding: 40px;
