---
import type { Locale } from '../i18n/index';
import { useTranslations, calculateReadingTime } from '../i18n/index';

interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  pubDate: Date;
  heroImage: string;
  heroImageAlt: string;
  readingTime?: number;
  body?: string;
  locale: Locale;
  animationDelay?: number;
}

const {
  title,
  description,
  slug,
  category,
  pubDate,
  heroImage,
  heroImageAlt,
  readingTime,
  body = '',
  locale,
  animationDelay = 0,
} = Astro.props;

const t = useTranslations(locale);
const rt = readingTime ?? calculateReadingTime(body);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const lp = locale === 'en' ? base : `${base}${locale}/`;
const href = `${lp}articulos/${slug}/`;
const formattedDate = new Intl.DateTimeFormat(locale === 'es' ? 'es-ES' : locale === 'pl' ? 'pl-PL' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}).format(pubDate);
---

<article
  class="animate-in group flex flex-col rounded-2xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg)] hover:-translate-y-0.5 transition-all duration-200 hover:shadow-lg"
  style={`animation-delay: ${animationDelay}ms; --tw-shadow-color: var(--color-card-hover-shadow);`}
>
  <a href={href} class="block overflow-hidden aspect-video bg-[var(--color-border)]">
    <img
      src={heroImage}
      alt={heroImageAlt}
      width="600"
      height="338"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </a>
  <div class="flex flex-col flex-1 p-5 gap-3">
    <div class="flex items-center gap-1.5">
      <span class="text-[11px] font-bold uppercase tracking-[0.06em] text-[var(--color-text-muted)]">
        {t.categories[category as keyof typeof t.categories] ?? category}
      </span>
      <span class="text-[11px] text-[var(--color-text-muted)]">&middot;</span>
      <span class="text-[11px] font-bold uppercase tracking-[0.06em] text-[var(--color-text-muted)]">{rt} {t.article.readingTime}</span>
    </div>
    <h3 class="font-display text-lg leading-tight line-clamp-2" style="font-family: var(--font-display);">
      <a href={href} class="hover:opacity-70 transition-opacity duration-200">
        {title.toUpperCase()}
      </a>
    </h3>
    <p class="text-sm text-[var(--color-text-muted)] line-clamp-2 flex-1">{description}</p>
    <div class="flex items-center justify-between mt-auto pt-3 border-t border-[var(--color-border)]">
      <span class="text-xs text-[var(--color-text-muted)]">{formattedDate}</span>
      <a href={href} class="text-xs font-bold flex items-center gap-1 hover:opacity-60 transition-opacity duration-200">
        {t.article.readMore}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2.5 7H11.5M11.5 7L7.5 3M11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</article>
