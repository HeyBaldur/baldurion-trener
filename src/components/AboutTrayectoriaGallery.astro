---
interface Props {
  t: {
    sectionEyebrow: string;
    sectionTitleStart: string;
    sectionTitleEm: string;
    photos: {
      patada: { title: string; meta: string };
      kungfu: { title: string; meta: string };
      coach: { title: string; meta: string };
      sparring: { title: string; meta: string };
      certificado: { title: string; meta: string };
    };
  };
}

const { t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const bentoBase = "group relative rounded-[16px] overflow-hidden bg-light border border-[rgba(0,0,0,0.08)] dark:bg-dark-card dark:border-[rgba(255,255,255,0.08)] transition-[transform,border-color] duration-300 hover:-translate-y-[2px] hover:border-[rgba(212,232,74,0.3)]";
---

<section class="max-w-[1280px] mx-auto my-[80px] px-[32px] max-[640px]:my-[56px] max-[640px]:px-[16px]">

  <header class="text-center mb-[56px] max-[640px]:mb-[36px]">
    <span class="font-body inline-block text-[11px] font-bold tracking-[0.3em] uppercase mb-[16px] text-[#444] dark:text-lime">
      {t.sectionEyebrow}
    </span>
    <h2 class="font-display text-[64px] leading-[0.95] uppercase m-0 text-dark dark:text-white max-[1024px]:text-[48px] max-[640px]:text-[36px]">
      {t.sectionTitleStart} {t.sectionTitleEm}
    </h2>
  </header>

  <div class="bento-grid grid gap-[16px] max-[640px]:gap-[12px]"
    style="grid-template-columns: repeat(12, 1fr); grid-template-rows: 320px 320px 380px 480px;"
  >

    <div class={`bento-patada ${bentoBase}`} style="grid-column: 1 / 5; grid-row: 1 / 4;">
      <img src={`${base}images/about/trayectoria/02-patada-saco.jpg`} alt={t.photos.patada.title} loading="lazy"
        class="w-full h-full object-cover block transition-transform duration-[600ms] ease-[ease] group-hover:scale-[1.04]" />
      <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, transparent 50%, rgba(0,0,0,0.85) 100%);"></div>
      <div class="absolute bottom-[20px] left-[20px] right-[20px] z-[2] text-light pointer-events-none">
        <div class="font-body text-[16px] font-bold leading-[1.3] mb-[4px]">{t.photos.patada.title}</div>
        <div class="font-body text-[11px] text-lime font-bold tracking-[0.2em] uppercase">{t.photos.patada.meta}</div>
      </div>
    </div>

    <div class={`bento-kungfu ${bentoBase}`} style="grid-column: 5 / 13; grid-row: 1 / 3;">
      <img src={`${base}images/about/trayectoria/01-kung-fu-maestro.jpg`} alt={t.photos.kungfu.title} loading="lazy"
        class="w-full h-full object-cover block transition-transform duration-[600ms] ease-[ease] group-hover:scale-[1.04]" />
      <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, transparent 50%, rgba(0,0,0,0.85) 100%);"></div>
      <div class="absolute bottom-[20px] left-[20px] right-[20px] z-[2] text-light pointer-events-none">
        <div class="font-body text-[16px] font-bold leading-[1.3] mb-[4px]">{t.photos.kungfu.title}</div>
        <div class="font-body text-[11px] text-lime font-bold tracking-[0.2em] uppercase">{t.photos.kungfu.meta}</div>
      </div>
    </div>

    <div class={`bento-coach ${bentoBase}`} style="grid-column: 5 / 9; grid-row: 3 / 4;">
      <img src={`${base}images/about/trayectoria/04-coach-gym.jpg`} alt={t.photos.coach.title} loading="lazy"
        class="w-full h-full object-cover block transition-transform duration-[600ms] ease-[ease] group-hover:scale-[1.04]" />
      <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, transparent 50%, rgba(0,0,0,0.85) 100%);"></div>
      <div class="absolute bottom-[20px] left-[20px] right-[20px] z-[2] text-light pointer-events-none">
        <div class="font-body text-[16px] font-bold leading-[1.3] mb-[4px]">{t.photos.coach.title}</div>
        <div class="font-body text-[11px] text-lime font-bold tracking-[0.2em] uppercase">{t.photos.coach.meta}</div>
      </div>
    </div>

    <div class={`bento-sparring ${bentoBase}`} style="grid-column: 9 / 13; grid-row: 3 / 4;">
      <img src={`${base}images/about/trayectoria/03-sparring-grupo.jpg`} alt={t.photos.sparring.title} loading="lazy"
        class="w-full h-full object-cover block transition-transform duration-[600ms] ease-[ease] group-hover:scale-[1.04]" />
      <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, transparent 50%, rgba(0,0,0,0.85) 100%);"></div>
      <div class="absolute bottom-[20px] left-[20px] right-[20px] z-[2] text-light pointer-events-none">
        <div class="font-body text-[16px] font-bold leading-[1.3] mb-[4px]">{t.photos.sparring.title}</div>
        <div class="font-body text-[11px] text-lime font-bold tracking-[0.2em] uppercase">{t.photos.sparring.meta}</div>
      </div>
    </div>

    <div class={`bento-cert ${bentoBase}`} style="grid-column: 1 / 13; grid-row: 4 / 5;">
      <img src={`${base}images/about/trayectoria/05-certificado-fitacademy.jpg`} alt={t.photos.certificado.title} loading="lazy"
        class="w-full h-full object-cover block transition-transform duration-[600ms] ease-[ease] group-hover:scale-[1.04]" />
      <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, transparent 50%, rgba(0,0,0,0.85) 100%);"></div>
      <div class="absolute bottom-[20px] left-[20px] right-[20px] z-[2] text-light pointer-events-none">
        <div class="font-body text-[16px] font-bold leading-[1.3] mb-[4px]">{t.photos.certificado.title}</div>
        <div class="font-body text-[11px] text-lime font-bold tracking-[0.2em] uppercase">{t.photos.certificado.meta}</div>
      </div>
    </div>

  </div>
</section>

<style is:global>
  /* Bento grid — responsive grid-template cannot be expressed as Tailwind arbitrary breakpoint on the same element */
  @media (max-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(6, 1fr) !important;
      grid-template-rows: 280px 280px 280px 360px !important;
    }
    .bento-patada   { grid-column: 1 / 4 !important; grid-row: 1 / 3 !important; }
    .bento-kungfu   { grid-column: 4 / 7 !important; grid-row: 1 / 3 !important; }
    .bento-coach    { grid-column: 1 / 4 !important; grid-row: 3 / 4 !important; }
    .bento-sparring { grid-column: 4 / 7 !important; grid-row: 3 / 4 !important; }
    .bento-cert     { grid-column: 1 / 7 !important; grid-row: 4 / 5 !important; }
  }
  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: 1fr !important;
      grid-template-rows: none !important;
      grid-auto-rows: auto;
    }
    .bento-patada, .bento-kungfu, .bento-coach, .bento-sparring, .bento-cert {
      grid-column: 1 / 2 !important;
      grid-row: auto !important;
    }
    .bento-patada   { aspect-ratio: 4 / 5; }
    .bento-kungfu   { aspect-ratio: 16 / 10; }
    .bento-coach    { aspect-ratio: 1 / 1; }
    .bento-sparring { aspect-ratio: 1 / 1; }
    .bento-cert     { aspect-ratio: 16 / 9; }
  }
</style>
