---
interface Props {
  t: {
    sectionEyebrow: string;
    sectionTitleStart: string;
    sectionTitleEm: string;
    photos: {
      patada: { title: string; meta: string };
      kungfu: { title: string; meta: string };
      coach: { title: string; meta: string };
      sparring: { title: string; meta: string };
      certificado: { title: string; meta: string };
    };
  };
}

const { t } = Astro.props;
const base = (import.meta.env.BASE_URL ?? '/').replace(/([^/])$/, '$1/');
---

<section class="trayectoria-gallery">
  <header class="trayectoria-gallery__header">
    <span class="trayectoria-gallery__eyebrow">{t.sectionEyebrow}</span>
    <h2 class="trayectoria-gallery__title">
      {t.sectionTitleStart} <span class="trayectoria-gallery__title-em">{t.sectionTitleEm}</span>
    </h2>
  </header>

  <div class="trayectoria-gallery__grid">

    <div class="bento-item bento-item--patada">
      <img src={`${base}images/about/trayectoria/02-patada-saco.jpg`} alt={t.photos.patada.title} loading="lazy" />
      <div class="bento-item__caption">
        <div class="bento-item__caption-title">{t.photos.patada.title}</div>
        <div class="bento-item__caption-meta">{t.photos.patada.meta}</div>
      </div>
    </div>

    <div class="bento-item bento-item--kungfu">
      <img src={`${base}images/about/trayectoria/01-kung-fu-maestro.jpg`} alt={t.photos.kungfu.title} loading="lazy" />
      <div class="bento-item__caption">
        <div class="bento-item__caption-title">{t.photos.kungfu.title}</div>
        <div class="bento-item__caption-meta">{t.photos.kungfu.meta}</div>
      </div>
    </div>

    <div class="bento-item bento-item--coach">
      <img src={`${base}images/about/trayectoria/04-coach-gym.jpg`} alt={t.photos.coach.title} loading="lazy" />
      <div class="bento-item__caption">
        <div class="bento-item__caption-title">{t.photos.coach.title}</div>
        <div class="bento-item__caption-meta">{t.photos.coach.meta}</div>
      </div>
    </div>

    <div class="bento-item bento-item--sparring">
      <img src={`${base}images/about/trayectoria/03-sparring-grupo.jpg`} alt={t.photos.sparring.title} loading="lazy" />
      <div class="bento-item__caption">
        <div class="bento-item__caption-title">{t.photos.sparring.title}</div>
        <div class="bento-item__caption-meta">{t.photos.sparring.meta}</div>
      </div>
    </div>

    <div class="bento-item bento-item--certificado">
      <img src={`${base}images/about/trayectoria/05-certificado-fitacademy.jpg`} alt={t.photos.certificado.title} loading="lazy" />
      <div class="bento-item__caption">
        <div class="bento-item__caption-title">{t.photos.certificado.title}</div>
        <div class="bento-item__caption-meta">{t.photos.certificado.meta}</div>
      </div>
    </div>

  </div>
</section>

<style>
  .trayectoria-gallery {
    max-width: 1280px;
    margin: 80px auto 80px;
    padding: 0 32px;
  }

  .trayectoria-gallery__header {
    text-align: center;
    margin-bottom: 56px;
  }

  .trayectoria-gallery__eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #D4E84A;
    margin-bottom: 16px;
  }

  :global([data-theme="light"]) .trayectoria-gallery__eyebrow {
    color: #444;
  }

  .trayectoria-gallery__title {
    font-family: var(--font-display);
    font-size: 64px;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .trayectoria-gallery__title-em {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    text-transform: lowercase;
    color: #D4E84A;
  }

  :global([data-theme="light"]) .trayectoria-gallery__title-em {
    color: #0A0A0A;
  }

  .trayectoria-gallery__grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: 320px 320px 380px 480px;
    gap: 16px;
  }

  .bento-item {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: transform 300ms ease, border-color 300ms ease;
  }

  :global([data-theme="light"]) .bento-item {
    background: #FAFAF7;
    border-color: rgba(0, 0, 0, 0.08);
  }

  .bento-item:hover {
    transform: translateY(-2px);
    border-color: rgba(212, 232, 74, 0.3);
  }

  .bento-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms ease;
  }

  .bento-item:hover img {
    transform: scale(1.04);
  }

  .bento-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, transparent 50%, rgba(0,0,0,0.85) 100%);
    pointer-events: none;
  }

  .bento-item__caption {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    z-index: 2;
    color: #FAFAF7;
    pointer-events: none;
  }

  .bento-item__caption-title {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 4px;
  }

  .bento-item__caption-meta {
    font-size: 11px;
    color: #D4E84A;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .bento-item--patada {
    grid-column: 1 / 5;
    grid-row: 1 / 4;
  }

  .bento-item--kungfu {
    grid-column: 5 / 13;
    grid-row: 1 / 3;
  }

  .bento-item--coach {
    grid-column: 5 / 9;
    grid-row: 3 / 4;
  }

  .bento-item--sparring {
    grid-column: 9 / 13;
    grid-row: 3 / 4;
  }

  .bento-item--certificado {
    grid-column: 1 / 13;
    grid-row: 4 / 5;
  }

  @media (max-width: 1024px) {
    .trayectoria-gallery__grid {
      grid-template-columns: repeat(6, 1fr);
      grid-template-rows: 280px 280px 280px 360px;
    }

    .bento-item--patada {
      grid-column: 1 / 4;
      grid-row: 1 / 3;
    }

    .bento-item--kungfu {
      grid-column: 4 / 7;
      grid-row: 1 / 3;
    }

    .bento-item--coach {
      grid-column: 1 / 4;
      grid-row: 3 / 4;
    }

    .bento-item--sparring {
      grid-column: 4 / 7;
      grid-row: 3 / 4;
    }

    .bento-item--certificado {
      grid-column: 1 / 7;
      grid-row: 4 / 5;
    }

    .trayectoria-gallery__title { font-size: 48px; }
  }

  @media (max-width: 640px) {
    .trayectoria-gallery { margin: 56px auto 56px; padding: 0 16px; }

    .trayectoria-gallery__grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-auto-rows: auto;
      gap: 12px;
    }

    .bento-item {
      grid-column: 1 / 2 !important;
      grid-row: auto !important;
    }

    .bento-item--patada { aspect-ratio: 4 / 5; }
    .bento-item--kungfu { aspect-ratio: 16 / 10; }
    .bento-item--coach { aspect-ratio: 1 / 1; }
    .bento-item--sparring { aspect-ratio: 1 / 1; }
    .bento-item--certificado { aspect-ratio: 16 / 9; }

    .trayectoria-gallery__title { font-size: 36px; }
    .trayectoria-gallery__header { margin-bottom: 36px; }
  }
</style>
